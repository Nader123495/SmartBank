# Copier ce fichier vers .env et adapter les valeurs.

# Mot de passe SA SQL Server (exigences Microsoft : majuscule, minuscule, chiffre, symbole, 8+ caractères)
MSSQL_SA_PASSWORD=Your_strong_Password123!

# Clé JWT (min. 32 caractères). Évitez « ! » seul dans docker-compose.yml ; ici dans .env c’est permis.
JWT_KEY=SmartBank_STB2025_SecretKey_MinLength32Chars_XX

# URL Ollama vue depuis le conteneur API (Docker Desktop Windows/Mac : host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
